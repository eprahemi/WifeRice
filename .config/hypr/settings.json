{
  "uiScale": 1,
  "openGuideAtStartup": true,
  "topbarHelpIcon": false,
  "workspaceCount": 7,
  "wallpaperDir": "",
  "language": "us,ara",
  "kbOptions": "grp:alt_shift_toggle",
  "monitors": [
    {
      "name": "eDP-1",
      "resW": 1920,
      "resH": 1080,
      "rate": 60,
      "x": 0,
      "y": 0,
      "scale": 1,
      "transform": 0
    }
  ],
  "keybinds": [],
  "startup": [
    {
      "command": "systemctl --user start hyprpolkitagent"
    },
    {
      "command": "awww-daemon"
    },
    {
      "command": "hypridle"
    },
    {
      "command": "quickshell -p ~/.config/hypr/scripts/quickshell/Main.qml"
    },
    {
      "command": "quickshell -p ~/.config/hypr/scripts/quickshell/TopBar.qml"
    },
    {
      "command": "quickshell -p ~/.config/hypr/scripts/quickshell/Floating.qml"
    },
    {
      "command": "python3 ~/.config/hypr/scripts/quickshell/focustime/focus_daemon.py &"
    },
    {
      "command": "~/.config/hypr/scripts/init.sh"
    },
    {
      "command": "~/.config/hypr/scripts/settings_watcher.sh &"
    },
    {
      "command": "playerctld"
    },
    {
      "command": "swayosd-server --top-margin 0.9 --style \"$HOME/.config/swayosd/style.css\""
    },
    {
      "command": "wl-paste --type text --watch cliphist store"
    },
    {
      "command": "wl-paste --type image --watch cliphist store"
    },
    {
      "command": "~/.config/hypr/scripts/volume_listener.sh"
    },
    {
      "command": "~/.config/hypr/scripts/update_notifier.sh"
    }
  ]
}
